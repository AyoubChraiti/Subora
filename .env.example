# PostgreSQL
POSTGRES_DB=subora
POSTGRES_USER=subora
POSTGRES_PASSWORD=subora_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg2://subora:subora_password@db:5432/subora
SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:3000
AUTH_RATE_LIMIT=5/minute
DEFAULT_RATE_LIMIT=60/minute

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000
